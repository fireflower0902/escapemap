# ── 절대 Git에 올리면 안 되는 것들 ──────────────────────────
.env                    # API 키, 비밀번호가 담긴 환경 변수 파일
*.db                    # SQLite 데이터베이스 파일
*.db-shm
*.db-wal

# ── Python 빌드/캐시 파일 ────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
dist/
build/
*.egg-info/

# ── 가상환경 ──────────────────────────────────────────────────
.venv/
venv/
env/

# ── IDE 설정 파일 ─────────────────────────────────────────────
.vscode/
.idea/
*.swp

# ── Playwright 브라우저 바이너리 ─────────────────────────────
