# ============================================================
# .env.example — 실제 값을 채워서 .env 파일로 복사하여 사용
# 주의: .env 파일은 절대 Git에 올리지 마세요! (비밀번호 유출 위험)
# ============================================================

# ── 데이터베이스 ─────────────────────────────────────────────
# 개발 중에는 SQLite 사용 (아래 주석 해제)
DATABASE_URL=sqlite+aiosqlite:///./escape_aggregator.db

# 배포 시에는 PostgreSQL 사용 (아래 주석 해제 후 실제 값 입력)
# DATABASE_URL=postgresql+asyncpg://유저명:비밀번호@호스트:5432/데이터베이스명

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── 카카오맵 API ──────────────────────────────────────────────
# 카카오 개발자 콘솔(developers.kakao.com)에서 발급
KAKAO_REST_API_KEY=여기에_카카오_API_키_입력

# ── 이메일 알림 (Resend) ─────────────────────────────────────
# resend.com에서 가입 후 발급
RESEND_API_KEY=여기에_Resend_API_키_입력

# ── 카카오 알림톡 ────────────────────────────────────────────
# 카카오 비즈니스 채널 등록 후 발급
KAKAO_CHANNEL_PUBLIC_KEY=여기에_카카오_채널_키_입력

# ── 모니터링 (Sentry) ────────────────────────────────────────
# sentry.io에서 프로젝트 생성 후 발급 (선택사항)
SENTRY_DSN=

# ── 앱 환경 설정 ──────────────────────────────────────────────
ENVIRONMENT=development   # development | production
CACHE_TTL_SECONDS=300     # 캐시 유지 시간 (초). 300 = 5분
